{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "lib": ["ES2021", "DOM"],
    "moduleResolution": "node16",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "isolatedModules": true,
    "types": ["node", "playwright"]
  },
  "include": ["tests/**/*.ts", "playwright.config.ts", "utils/**/*.ts", "src/**/*.ts"]
}
